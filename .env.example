# ─── Data & ports (server vs local) ───────────────────────────
# Server: use absolute path so Postgres/Valkey data persist on host.
# Local:  use ./data or leave DATA_PATH unset (defaults to ./data).
DATA_PATH=./data

# Optional: override published ports (API is internal only; reverse proxy talks to ivdrive-api:8000)
# WEB_PORT=CHANGE_ME
# POSTGRES_PORT=CHANGE_ME

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=ivdrive
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ivdrive

# ─── Valkey ───────────────────────────────────────────────────
VALKEY_PASSWORD=CHANGE_ME

# ─── JWT (access tokens signed with this key) ────────────────
JWT_SECRET_KEY=CHANGE_ME_TO_RANDOM_64_CHAR_STRING

# ─── AES-256-GCM (encrypts VINs, Skoda creds, tokens at rest)─
ENCRYPTION_KEY=CHANGE_ME_TO_BASE64_32_BYTE_KEY

# ─── CORS (allowed frontend origins) ─────────────────────────
CORS_ORIGINS=["http://localhost:3000"]

# ─── Frontend (baked in at build time) ────────────────────────
# Empty = browser uses same origin (/api/*). Set only if API is on a different host.
# For https://ivdrive.eu with reverse proxy: leave empty so login calls https://ivdrive.eu/api/...
NEXT_PUBLIC_API_URL=

# ─── Backend logging & collector ──────────────────────────────
# LOG_LEVEL=info   (or debug to see collector API summary when COLLECTOR_DEBUG=true)
# COLLECTOR_DEBUG=false   Logs parsed API response summary (charging power/rate, driving range, connection) per vehicle poll.
# STATISTICS_QUERY_DEBUG=fase Logs query parameters and results for statistics API calls.

# ─── Service Registration ─────────────────────────────────────
SERVICE_REGISTRATION=open # Open = anyone can register a new service; Invite-only = only admins can invite new user to service.

# ─── SMTP ─────────────────────────────────────────────────────
SMTP_HOST=CHANGE_ME
SMTP_PORT=587
SMTP_USER=CHANGE_ME
SMTP_PASS=CHANGE_ME
SMTP_FROM=CHANGE_ME

# ─── APP_BASE_URL ────────────────────────────────────────────
APP_BASE_URL=http://localhost:3000

# ─── IVDRIVE_VERSION ──────────────────────────────────────────
IVDRIVE_VERSION=v1.0.6